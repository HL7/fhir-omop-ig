/// url = 'http://hl7.org/fhir/uv/omop/StructureMap/BloodPressureDiastolicMap'
/// name = 'BloodPressureDiastolicMap'
/// title = 'Mapping Blood Pressure Diastolic component to OMOP Measurement'
/// status = 'draft'
/// description = "Extracts diastolic (LOINC 8462-4, concept 3012888) from BP panel Observation to OMOP Measurement. Uses suffix Measurement-Diastolic for distinct measurement_id vs BloodPressureSystolicMap."

uses "http://hl7.org/fhir/StructureDefinition/bp" alias BloodPressure as source
uses "http://hl7.org/fhir/uv/omop/StructureDefinition/Measurement" alias MeasureTable as target

group diastolicMap(source src : BloodPressure, target tgt : MeasureTable) {
    src.id as id -> tgt.measurement_id = cast(id, "integer") "measurement-id";
    src.subject as s -> tgt then {
        s.reference as ref -> tgt.person_id = cast(ref.replaceMatches('.*/', ''), "integer");
    } "person-id";
    src.encounter as e -> tgt then {
        e.reference as ref -> tgt.visit_occurrence_id = cast(ref.replaceMatches('.*/', ''), "integer");
    } "visit-id";
    src -> tgt.measurement_concept_id = 3012888 "concept-id";
    src -> tgt.measurement_type_concept_id = 32817 "type-concept-id";
    src.effective : dateTime as edt -> tgt.measurement_datetime = edt, tgt.measurement_date = (edt.toString().substring(0,10)) "datetime";
    src.component as comp where (comp.code.coding.code = '8462-4') -> tgt then {
        comp.value : Quantity as qty -> tgt then {
            qty.value as v -> tgt.value_as_number = v;
            qty.unit as u -> tgt.unit_source_value = u;
        } "diastolic-value";
    } "diastolic-component";
}
